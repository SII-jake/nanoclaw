# NanoClaw Configuration

# Assistant Settings
ASSISTANT_NAME=Andy
ASSISTANT_HAS_OWN_NUMBER=false

# WhatsApp Settings (set to false to disable)
WHATSAPP_ENABLED=true

# Feishu (Lark) Settings
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_ENCRYPT_KEY=your_encrypt_key
FEISHU_PORT=3000

# Anthropic API Settings
ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_BASE_URL=https://your-custom-endpoint.com/v1  # Optional: custom API endpoint
# ANTHROPIC_MODEL=claude-opus-4-5-20251101  # Optional: specify model version

# Container Settings
CONTAINER_IMAGE=nanoclaw-agent:latest
CONTAINER_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5
